   "source": [
    "drivers_agg = (df_results.groupby(\"driverId\")\n",
    "                      .agg(mean_points = ('points','mean'),\n",
    "                           sd_points =   ('points','std'),\n",
    "                           min_points =  ('points','min'),\n",
    "                           max_points =  ('points','max'),\n",
    "                           appearances   = ('points',len)))\n",
    "\n",
    "print(type(drivers_agg))\n",
    "display(drivers_agg)"
   ]
  },
