      "    ...                    [4, 5, 6],\n",
      "    ...                    [7, 8, 9],\n",
      "    ...                    [np.nan, np.nan, np.nan]],\n",
      "    ...                   columns=['A', 'B', 'C'])\n",
      "\n",
      "    Aggregate these functions over the rows.\n",
      "\n",
      "    >>> df.agg(['sum', 'min'])\n",
      "            A     B     C\n",
      "    sum  12.0  15.0  18.0\n",
      "    min   1.0   2.0   3.0\n",
      "\n",
      "    Different aggregations per column.\n",
